# NextAuth Authentication Provider Parameters
AUTH_SECRET="fallback_nexus_enterprise_secret_token_key_v2" # Run `npx auth secret` to generate a secure hash

# GitHub OAuth Client Scopes
GITHUB_ID="your_github_oauth_app_client_id"
